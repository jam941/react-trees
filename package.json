{
  "name": "react-process-graph-workspace",
  "private": true,
  "scripts": {
    "build": "pnpm --filter react-process-graph build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @internal/tests exec playwright test --project=e2e",
    "test:visual": "pnpm --filter @internal/tests exec playwright test --project=visual",
    "test:perf": "pnpm --filter @internal/tests exec playwright test --project=perf",
    "test:a11y": "pnpm --filter @internal/tests exec playwright test --project=a11y",
    "storybook": "pnpm --filter @internal/storybook storybook",
    "gallery": "pnpm --filter @internal/gallery dev",
    "build:storybook": "pnpm --filter @internal/storybook build",
    "build:gallery": "pnpm --filter @internal/gallery build"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "typescript-eslint": "^8.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@swc/core", "esbuild"]
  }
}
